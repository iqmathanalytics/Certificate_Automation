PORT=3002
NODE_ENV=development
CLIENT_URLS=http://localhost:5174,http://localhost:8080,http://localhost:5173
PUBLIC_SITE_URL=https://www.iqmath.in

# TiDB Cloud (MySQL-compatible). Place isrgrootx1.pem next to package.json.
# Do NOT use the system schema "sys" — use an app database e.g. certificate_automation
# DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/certificate_automation?sslaccept=strict&sslcert=./isrgrootx1.pem"
DATABASE_URL=

# Admin login (UI at /certificates/login)
ADMIN_EMAIL=contact@iqmath.in
ADMIN_PASSWORD=change-me
AUTH_SECRET=change-me-to-a-long-random-string

# Email (SMTP) — Gmail / Google Workspace for contact@iqmath.in
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@iqmath.in
SMTP_PASS=
SMTP_FROM_NAME=IQmath Technologies
SMTP_FROM_EMAIL=contact@iqmath.in
